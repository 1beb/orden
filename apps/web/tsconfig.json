{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["vite/client"],
    "paths": {
      "@orden/annotation-core": ["../../packages/annotation-core/src/index.ts"],
      "@orden/outliner": ["../../packages/outliner/src/index.ts"]
    }
  },
  "include": ["src"]
}
