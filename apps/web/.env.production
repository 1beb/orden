# Production build (served by apps/host) connects its Host RPC over a WebSocket
# to whatever origin served the page — so one build works local AND over the
# tailnet. "auto" → ws(s)://<location.host>. Dev (`vite`) leaves this unset and
# uses the in-browser BrowserHost. See apps/web/src/host/index.ts.
VITE_ORDEN_HOST=auto
