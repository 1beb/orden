# Dev (`vite`) connects its Host RPC to the local NodeHost over a WebSocket, so
# the dev server reads/writes the SAME shared vault as the host-served build —
# not the in-browser localStorage BrowserHost. Without this, `vite` on :5173
# silently diverges onto a separate browser-local store. See src/host/index.ts.
VITE_ORDEN_HOST=ws://127.0.0.1:4319
